{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://placeholder.example/flownote.trace.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "entry", "steps"],
  "properties": {
    "version": {
      "type": "number"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line"],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "number",
          "minimum": 1
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "file", "line", "title", "summary", "depth"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "number",
            "minimum": 0
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "depth": {
            "type": "number",
            "minimum": 0
          },
          "next": {
            "type": "string",
            "minLength": 1
          },
          "parentStepId": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": ["call", "enter", "return", "resume"]
          },
          "range": {
            "type": "object",
            "additionalProperties": false,
            "required": ["startLine", "endLine"],
            "properties": {
              "startLine": {
                "type": "number",
                "minimum": 1
              },
              "endLine": {
                "type": "number",
                "minimum": 1
              },
              "startColumn": {
                "type": "number",
                "minimum": 1
              },
              "endColumn": {
                "type": "number",
                "minimum": 1
              }
            }
          },
          "code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
