{
  "name": "flownote",
  "displayName": "FlowNote",
  "version": "0.0.4",
  "description": "Trace AI-generated code-flow JSON files inside VS Code.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "flow",
    "navigation",
    "trace",
    "json"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shimaf4979/flownote"
  },
  "icon": "icon.png",
  "publisher": "shimaf4979",
  "files": [
    "dist",
    "examples",
    "icon.png",
    "README.md",
    "LICENSE",
    "prompt.gif",
    "trace003.gif"
  ],
  "type": "commonjs",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit -p ./tsconfig.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "package": "pnpm build && vsce package --no-dependencies",
    "publish:dry-run": "pnpm build && vsce publish --no-dependencies --dry-run",
    "publish:vsce": "pnpm build && vsce publish --no-dependencies",
    "publish:ovsx": "pnpm build && ovsx publish --no-dependencies"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.10",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flownote",
          "title": "FlowNote",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "flownote": [
        {
          "id": "flownote.controls",
          "name": "Flow Controls",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "flownote.openTrace",
        "title": "FlowNote: Open Trace"
      },
      {
        "command": "flownote.nextStep",
        "title": "FlowNote: Next Step"
      },
      {
        "command": "flownote.previousStep",
        "title": "FlowNote: Previous Step"
      },
      {
        "command": "flownote.previousCallStep",
        "title": "FlowNote: Previous Parent Call"
      },
      {
        "command": "flownote.nextResumeStep",
        "title": "FlowNote: Next Parent Resume"
      },
      {
        "command": "flownote.copyPromptForAi",
        "title": "FlowNote: Copy Prompt for AI"
      },
      {
        "command": "flownote.createExampleTodoFiles",
        "title": "FlowNote: Create Todo Example Files"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "flownote.openTrace",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "flownote.nextStep",
          "when": "editorTextFocus",
          "group": "navigation"
        },
        {
          "command": "flownote.previousStep",
          "when": "editorTextFocus",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "flownote.previousStep",
        "key": "up",
        "when": "webviewFocus"
      },
      {
        "command": "flownote.nextStep",
        "key": "down",
        "when": "webviewFocus"
      },
      {
        "command": "flownote.previousCallStep",
        "key": "left",
        "when": "webviewFocus"
      },
      {
        "command": "flownote.nextResumeStep",
        "key": "right",
        "when": "webviewFocus"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:flownote.controls",
    "onCommand:flownote.openTrace",
    "onCommand:flownote.nextStep",
    "onCommand:flownote.previousStep",
    "onCommand:flownote.previousCallStep",
    "onCommand:flownote.nextResumeStep",
    "onCommand:flownote.copyPromptForAi",
    "onCommand:flownote.createExampleTodoFiles"
  ],
  "engines": {
    "vscode": "^1.95.0"
  }
}
